RewriteEngine On

# DirectorySlash 保持默认 On — admin 和 search 由 Apache 自动补斜杠后正常路由
# 前台路由精确匹配
RewriteRule ^list$ /article-list [R=301,L]
RewriteRule ^article-list$ index.php [L,QSA]
RewriteRule ^drone-list$ index.php [L,QSA]
RewriteRule ^software-list$ index.php [L,QSA]
RewriteRule ^tag-doc$ index.php [L,QSA]
RewriteRule ^detail$ index.php [L,QSA]
RewriteRule ^search/?$ index.php [L,QSA]
RewriteRule ^favorites$ index.php [L,QSA]
RewriteRule ^login$ index.php [L,QSA]

# 如果请求的是真实文件或目录，直接访问
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# admin api 模块 URL 重写
RewriteRule ^admin/api/([^/]+)$ admin/api/$1.php [L,QSA]

# 核心 api 模块 URL 重写
RewriteRule ^api/([^/]+)$ api/$1.php [L,QSA]

# search 模块 URL 重写
RewriteRule ^search/api/list$ search/api/list.php [L,QSA]
RewriteRule ^search/api/([^/]+)$ search/api/$1.php [L,QSA]

# article 模块 URL 重写
RewriteRule ^article/api/list$ article/api/list.php [L,QSA]
RewriteRule ^article/api/([^/]+)$ article/api/$1.php [L,QSA]

# software 模块 URL 重写
RewriteRule ^software/api/list$ software/api/list.php [L,QSA]
RewriteRule ^software/api/([^/]+)$ software/api/$1.php [L,QSA]

# 前台页面路由 → index.php（/list, /detail, /search, /favorites, /login 等）
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L,QSA]
